<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="XiaoZhi Notify"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chuyển thông báo điện thoại lên đồng hồ. Tự tìm đồng hồ trong WiFi, không cần nhập IP."
            android:textSize="13sp"
            android:paddingBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGrant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Cấp quyền đọc thông báo" />

        <TextView
            android:id="@+id/lblAccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp"
            android:text="Trạng thái quyền: ?" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="2. Token (xem ở trang /notify trên đồng hồ)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Lưu token" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IP đồng hồ (tùy chọn — chỉ khi tự dò không ra)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.Button.TonalButton"
            android:text="Lưu IP thủ công" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/swEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bật chuyển thông báo" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/swOngoing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Gồm cả thông báo thường trú (đang phát nhạc, tải...)" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chọn ứng dụng gửi" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDiscover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Button.TonalButton"
            android:text="Tìm đồng hồ trong WiFi" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Material3.Button.TonalButton"
            android:text="Gửi thử" />

        <TextView
            android:id="@+id/lblInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:textSize="13sp"
            android:text="" />
    </LinearLayout>
</ScrollView>
